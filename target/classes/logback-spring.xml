<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Default console appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %5level --- [%thread] %-40.40logger{39} : %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Custom SSE stream appender -->
    <appender name="SSE_STREAM" class="aiman.dev.jobtracker.config.LogStreamAppender" />

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="SSE_STREAM" />
    </root>
</configuration>
